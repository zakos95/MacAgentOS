  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PROJECT_ROOT}"
      ]
    },
    "mac-control": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${PROJECT_ROOT}/mac_server.py"
      ]
    },
    "safari": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${PROJECT_ROOT}/mcp_safari.py"
      ]
    },
    "chatgpt": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${MCP_DYNAMIC}/mcp_ChatGPT.py"
      ]
    },
    "google_chrome": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${MCP_DYNAMIC}/mcp_Google_Chrome.py"
      ]
    },
    "vlc": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${MCP_DYNAMIC}/mcp_VLC.py"
      ]
    },
    "claude": {
      "command": "${VENV_PYTHON}",
      "args": [
        "${MCP_DYNAMIC}/mcp_Claude.py"
      ]
    }
  },
  "available_servers": [
    "filesystem",
    "mac-control",
    "safari"
  ],
  "configurable_servers": [
    {
      "id": "github",
      "name": "GitHub",
      "env_vars": [
        "GITHUB_PERSONAL_ACCESS_TOKEN"
      ],
      "enabled": false
    },
    {
      "id": "slack",
      "name": "Slack",
      "env_vars": [
        "SLACK_BOT_TOKEN",
        "SLACK_TEAM_ID"
      ],
      "enabled": false
    },
    {
      "id": "postgres",
      "name": "PostgreSQL",
      "env_vars": [
        "POSTGRES_CONNECTION_STRING"
      ],
      "enabled": false
    },
    {
      "id": "brave-search",
      "name": "Brave Search",
      "env_vars": [
        "BRAVE_API_KEY"
      ],
      "enabled": false
    },
    {
      "id": "notion",
      "name": "Notion",
      "env_vars": [
        "NOTION_API_KEY"
      ],
      "enabled": false
    },
    {
      "id": "sentry",
      "name": "Sentry",
      "env_vars": [
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG"
      ],
      "enabled": false
    },
    {
      "id": "linear",
      "name": "Linear",
      "env_vars": [
        "LINEAR_API_KEY"
      ],
      "enabled": false
    },
    {
      "id": "gmail",
      "name": "Gmail",
      "env_vars": [
        "GMAIL_CREDENTIALS"
      ],
      "enabled": false
    },
    {
      "id": "google-drive",
      "name": "Google Drive",
      "env_vars": [
        "GOOGLE_CREDENTIALS"
      ],
      "enabled": false
    }
  ]
}